[Unit]
Description=IBKR Trader RL Runner
After=network-online.target ibkr-trader-api.service
Wants=network-online.target ibkr-trader-api.service

[Service]
Type=simple
WorkingDirectory=%h/ibkr-trader
Environment=PYTHONPATH=%h/ibkr-trader/src
ExecStartPre=/usr/bin/mkdir -p %h/ibkr-trader/var/rl-runner
ExecStartPre=/bin/sh -lc 'i=0; while [ "$$i" -lt 60 ]; do /usr/bin/curl -fsS http://127.0.0.1:8000/healthz >/dev/null 2>&1 && exit 0; i=$$((i + 1)); sleep 1; done; echo "API did not become ready for RL runner" >&2; exit 1'
ExecStart=%h/ibkr-trader/.venv/bin/python %h/ibkr-trader/scripts/run_rl_agents.py --api-base http://127.0.0.1:8000 --execute-virtual --state-file %h/ibkr-trader/var/rl-runner/state.json --history-cache-file %h/ibkr-trader/var/rl-runner/history-cache.json --allow-metadata-history-fallback --metadata-history-only
Restart=always
RestartSec=15
TimeoutStopSec=20

[Install]
WantedBy=default.target
