# Copy this file to ~/.config/ibgateway/ibgateway.env for the ibgateway user.
#
# This service model is session-bound: it attaches IBC and IB Gateway to the
# user's existing desktop display so that RDP disconnect/reconnect returns to
# the same visible screen. Keep DISPLAY and XAUTHORITY in session.env, not here.

IBG_TWS_MAJOR_VERSION=1045
IBG_IBC_PATH=/home/ibgateway/IBC
IBG_TWS_PATH=/home/ibgateway/Jts
IBG_IBC_INI=/home/ibgateway/IBC/config.ini
IBG_TRADING_MODE=live
IBG_TWOFA_TIMEOUT_ACTION=exit

# Optional overrides:
# IBG_TWS_SETTINGS_PATH=/home/ibgateway/Jts
# IBG_JAVA_PATH=/path/to/java/bin
