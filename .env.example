APP_ENV=dev
APP_TIMEZONE=Europe/Stockholm
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ibkr_trader
SESSION_CALENDAR_PATH=../q-data/xsto/calendars/day_sessions.parquet
XSTO_INSTRUMENTS_PATH=../q-data/xsto/instruments/all.txt
XSTO_IDENTITY_PATH=../q-data/xsto/meta/instrument_identity.parquet
API_HOST=127.0.0.1
API_PORT=8000
API_REQUIRE_LOOPBACK_ONLY=true
# Canonical IBKR client IDs:
# 0 = runtime, 7 = diagnostics, 9 = streaming, 10000-19999 = ad hoc scripts
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=0
IBKR_DIAGNOSTIC_CLIENT_ID=7
IBKR_STREAMING_CLIENT_ID=9
IBKR_ACCOUNT_ID=UXXXXXXX
BROKER_MONITOR_ENABLED=true
BROKER_HEARTBEAT_INTERVAL_SECONDS=30
BROKER_HEARTBEAT_TIMEOUT_SECONDS=5
BROKER_SNAPSHOT_REFRESH_INTERVAL_SECONDS=60
BROKER_SNAPSHOT_REFRESH_TIMEOUT_SECONDS=10
